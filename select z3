3. Средняя продолжительность треков по каждому альбому

SELECT a.title, AVG(t.duration) AS avg_duration
FROM albums a
JOIN tracks t ON a.id = t.album_id
GROUP BY a.title;

4. Исполнители, которые НЕ выпускали альбомы в 2020 году
SELECT name

FROM artists
WHERE id NOT IN (
    SELECT aa.artist_id
    FROM artist_albums aa
    JOIN albums a ON aa.album_id = a.id
    WHERE a.year = 2020
);

5. Сборники, в которых есть конкретный исполнитель

(пример: Imagine Dragons)

SELECT DISTINCT c.title
FROM collections c
JOIN collection_tracks ct ON c.id = ct.collection_id
JOIN tracks t ON ct.track_id = t.id
JOIN albums a ON t.album_id = a.id
JOIN artist_albums aa ON a.id = aa.album_id
JOIN artists ar ON aa.artist_id = ar.id
WHERE ar.name = 'Imagine Dragons';
